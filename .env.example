# ============================================
# AI Change Impact Analyzer - Environment Config
# ============================================
# Copy this to .env and fill in your values

# --- Provider Selection ---
# Options: mock, openai, groq, openrouter, ollama
# Controls ONLY the conversational /chat and /assistant endpoints.
AI_PROVIDER=mock

# Controls the deterministic multi-agent risk-analysis pipeline
# (/api/v1/change-impact/analyze, /api/v2/.../analyze-react). Deliberately
# separate from AI_PROVIDER and defaulted to mock: the pipeline runs 7
# agents per request, and pointing every agent at a live LLM serially makes
# a single "Analyze" click take 30-120+ seconds and time out/crash. Only
# change this if you want live-LLM narrative text inside the pipeline and
# have raised ai-service.timeout in the backend config to match.
PIPELINE_AI_PROVIDER=mock

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-opus

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- GCP Vertex AI (Module 3: RAG embeddings) ---
# If unset, the Historical Detective agent transparently falls back to the
# deterministic local embedding provider (no cloud dependency required).
GCP_PROJECT_ID=
GCP_REGION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-005

# --- ReAct pipeline execution caps (Module 5) ---
MAX_AUDITOR_CONTEXT_TOKENS=6000

# --- Direct Frontend-to-AI Mode ---
# Set to true to skip backend proxy for AI calls
VITE_DIRECT_AI_MODE=false

# --- AI Service URL ---
# The backend (and, if VITE_DIRECT_AI_MODE=true, the frontend) call this URL
# for /api/v1 and /api/v2 analysis endpoints. Defaults to the GCP Cloud Run
# deployment. Point it at http://localhost:8000 (or http://ai-service:8000
# inside docker-compose) to use a locally-run ai-service instead.
AI_SERVICE_URL=https://hackathonimpactanalyser-904105072538.asia-south1.run.app
VITE_AI_SERVICE_URL=https://hackathonimpactanalyser-904105072538.asia-south1.run.app

# --- Backend ---
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# --- AI Service (only used if you run ai-service locally via docker-compose) ---
AI_SERVICE_PORT=8000

