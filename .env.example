# ============================================
# AI Change Impact Analyzer - Environment Config
# ============================================
# Copy this to .env and fill in your values

# --- Provider Selection ---
# Options: mock, openai, groq, openrouter, ollama
AI_PROVIDER=mock

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# --- Groq ---
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-opus

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Direct Frontend-to-AI Mode ---
# Set to true to skip backend proxy for AI calls
VITE_DIRECT_AI_MODE=false
VITE_AI_SERVICE_URL=http://localhost:8000

# --- Backend ---
BACKEND_PORT=8081
SPRING_PROFILES_ACTIVE=dev

# --- AI Service ---
AI_SERVICE_PORT=8000

